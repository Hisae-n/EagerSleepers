# =========================
# Docker Compose settings
# =========================
APP_HOST=localhost
WEB_CLIENT_PORT=3000
WEB_SERVER_PORT=3001
VITE_DEV_SERVER_HOST=0.0.0.0
CHOKIDAR_USEPOLLING=true

# =========================
# PostgreSQL development database
# =========================
POSTGRES_DB=eager_sleepers
POSTGRES_USER=eager_sleepers
POSTGRES_PASSWORD=eager_sleepers
POSTGRES_PORT=5432

# =========================
# Wasp server environment
# Used by the web container
# =========================
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
WASP_WEB_CLIENT_URL=http://${APP_HOST}:${WEB_CLIENT_PORT}
WASP_SERVER_URL=http://${APP_HOST}:${WEB_SERVER_PORT}
PORT=${WEB_SERVER_PORT}
SKIP_EMAIL_VERIFICATION_IN_DEV=false

# =========================
# Wasp client environment
# Public values only
# =========================
REACT_APP_API_URL=http://${APP_HOST}:${WEB_SERVER_PORT}
